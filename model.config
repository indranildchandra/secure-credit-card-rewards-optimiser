# Model configuration for the Credit Card Optimiser agent.
# Change MODEL_PROVIDER and MODEL_NAME here to switch models globally.
# No code changes needed — just update this file and restart run.sh.

# --- Option 1: Local Ollama model (DEFAULT — fully offline / secure) ---
# Requires Ollama running: https://ollama.com
# Your transaction reasoning never leaves the machine. Only the live web-search
# step (merchant + card names, no amounts) reaches the internet.
# NOTE: Model MUST support tool calling — e.g. gemma3 does NOT support tools on
# Ollama and cannot be used. Recommended (all support tool calling):
#   gemma4:e2b   (~7.2GB) — Gemma 4, tools supported, good for 16GB RAM Macs
#   gemma4       (~9.6GB) — Gemma 4 default, better quality, needs 16GB+ RAM
#   qwen2.5:7b   (~4.7GB) — best tool-calling reliability among smaller models
#   llama3.1:8b  (~4.7GB) — strong overall quality
#   mistral:7b   (~4.1GB) — solid alternative
MODEL_PROVIDER=ollama
MODEL_NAME=gemma4:e2b
OLLAMA_API_BASE=http://localhost:11434
