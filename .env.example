# Environment variables for the Credit Card Optimiser.
#
# DEFAULT (Ollama / offline): you need NOTHING here — leave this file empty or
# don't create .env at all. The model runs locally via Ollama.
#
# Only required if you switch config/model.config to MODEL_PROVIDER=gemini
# (the optional cloud path). Copy this file to .env and fill in ONE option:
#
#   Option A — Gemini API key (from Google AI Studio):
# GOOGLE_API_KEY=your_api_key_here
#
#   Option B — Vertex AI (GCP project with billing + Application Default Creds):
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
